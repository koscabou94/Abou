# ============================================================
# Configuration de l'application - Chatbot Éducatif Sénégal
# Copiez ce fichier en .env et remplissez les valeurs
# IMPORTANT: Ne commitez JAMAIS le fichier .env dans git
# ============================================================

# === Base de données PostgreSQL ===
DATABASE_URL=postgresql+asyncpg://edu_user:edu_password@db:5432/edu_chatbot

# === Redis (cache) ===
REDIS_URL=redis://redis:6379/0

# === Sécurité ===
# OBLIGATOIRE: Changez ces valeurs en production !
SECRET_KEY=votre-cle-secrete-super-longue-et-aleatoire-minimum-32-chars
API_KEY=votre-cle-api-admin-securisee

# === Ollama (LLM principal) ===
OLLAMA_URL=http://ollama:11434
MODEL_NAME=mistral
FALLBACK_MODEL=TinyLlama/TinyLlama-1.1B-Chat-v1.0

# === Modèles NLP ===
TRANSLATION_MODEL=facebook/nllb-200-distilled-600M
EMBEDDING_MODEL=all-MiniLM-L6-v2

# === Paramètres de génération ===
MAX_TOKENS=512
TEMPERATURE=0.7
CONTEXT_WINDOW=5

# === Langues supportées ===
SUPPORTED_LANGUAGES=["fr","wo","ff","ar"]
PIVOT_LANGUAGE=fr

# === Mode allégé (pour zones à faibles ressources) ===
# Mettre à True pour désactiver Ollama et Redis
USE_LIGHTWEIGHT_MODE=False

# === Serveur ===
HOST=0.0.0.0
PORT=8000
DEBUG=False
WORKERS=2

# === CORS ===
# En production, listez les domaines autorisés
CORS_ORIGINS=["*"]

# === Seuils de correspondance FAQ ===
FAQ_MATCH_THRESHOLD=0.7
FAQ_HIGH_CONFIDENCE_THRESHOLD=0.85

# === Cache ===
CACHE_TTL_SECONDS=3600

# === Rate limiting ===
RATE_LIMIT_CHAT=20/minute
RATE_LIMIT_FAQ=100/minute

# === Chemins des données ===
FAQ_DATA_PATH=/app/data/faq_senegal.json
KNOWLEDGE_BASE_PATH=/app/data/knowledge_base.json

# === PostgreSQL (pour docker-compose) ===
POSTGRES_DB=edu_chatbot
POSTGRES_USER=edu_user
POSTGRES_PASSWORD=edu_password_changez_en_production
